{
  "productName": "SeekingData",
  "appId": "com.seekingdata.app",
  "asar": true,
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron",
    "dist",
    "!backend",
    "!**/__pycache__"
  ],
  "extraResources": [
    {
      "from": "backend",
      "to": "backend",
      "filter": ["**/*", "!.venv/**/*"]
    },
    {
      "from": "resources/prebuilt",
      "to": "prebuilt",
      "filter": [
        "**/*",
        "!cache/**/*",
        "!**/__pycache__",
        "!**/*.pyc"
      ]
    }
  ],
  "mac": {
    "icon": "build/icon.icns",
    "target": ["dmg", "zip"],
    "category": "public.app-category.developer-tools"
  },
  "win": {
    "icon": "build/icon.ico",
    "target": ["nsis"]
  },
  "linux": {
    "icon": "build/icon.png",
    "target": ["AppImage"],
    "category": "Development"
  },
  "publish": {
    "provider": "github",
    "owner": "seekingdata",
    "repo": "seekingdata"
  }
}
